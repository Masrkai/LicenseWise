      {"id": "CC-BY-SA-4.0", "note": "ShareAlike for derivative datasets"}
    ]
  },
  {
    "keywords": ["government", "public_sector", "eu", "european"],
    "suggestions": [
      {"id": "EUPL-1.2", "note": "Designed for EU law, legally valid across all EU jurisdictions"},
      {"id": "GPL-3.0", "note": "Strong copyleft for public works"},
