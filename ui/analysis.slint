import { LineEdit } from "std-widgets.slint";
import { Theme, YesNoSkipCombo, ActionButton, OutputScrollView } from "styles.slint";
import { ResultsPanel } from "results.slint";

export component AnalysisTab inherits VerticalLayout {
    spacing: 20px;
    padding: 0px;

    in-out property <string> license-id-input: "";
    in-out property <string> distribute-an: "skip";
    in-out property <string> saas-an: "skip";
    in-out property <string> commercial-an: "skip";
    in-out property <string> patent-an: "skip";
    in-out property <string> relicense-an: "skip";
    in-out property <string> output-text: "Compatibility results will appear here after clicking the button above";

    callback check-compatibility();

    Text {
        text: "Check License Compatibility";
        font-size: Theme.font-size-heading;
        color: Theme.text-color;
    }

    Text {
        text: "Enter a license ID and answer questions about your use case to check compatibility.";
        font-size: Theme.font-size-label;
        color: Theme.text-muted;
        wrap: word-wrap;
    }

    Rectangle {
        background: Theme.surface;
        border-radius: Theme.radius;
        border-width: 1px;
        border-color: Theme.border;
        clip: true;
        drop-shadow-offset-x: 0px;
        drop-shadow-offset-y: 1px;
        drop-shadow-blur: 4px;
        drop-shadow-color: rgba(0, 0, 0, 0.08);

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            Text {
                text: "License SPDX ID";
                font-size: Theme.font-size-label;
                color: Theme.text-color;
            }

            LineEdit {
                placeholder-text: "e.g., MIT, GPL-3.0, Apache-2.0, BSD-2-Clause";
                text <=> root.license-id-input;
                min-height: 44px;
            }
        }
    }

    Rectangle {
        background: Theme.surface;
        border-radius: Theme.radius;
        border-width: 1px;
        border-color: Theme.border;
        clip: true;
        drop-shadow-offset-x: 0px;
        drop-shadow-offset-y: 1px;
        drop-shadow-blur: 4px;
        drop-shadow-color: rgba(0, 0, 0, 0.08);

        VerticalLayout {
            padding: 20px;
            spacing: 16px;

            Text {
                text: "Your Use Case";
                font-size: Theme.font-size-subheading;
                color: Theme.text-color;
            }

            HorizontalLayout {
                spacing: 16px;

                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;
                    Text { text: "Will you distribute?"; font-size: 14px; color: Theme.text-muted; }
                    YesNoSkipCombo { current-value <=> root.distribute-an; }
                }

                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;
                    Text { text: "Used over network (SaaS)?"; font-size: 14px; color: Theme.text-muted; }
                    YesNoSkipCombo { current-value <=> root.saas-an; }
                }

                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;
                    Text { text: "Commercial use?"; font-size: 14px; color: Theme.text-muted; }
                    YesNoSkipCombo { current-value <=> root.commercial-an; }
                }
            }

            HorizontalLayout {
                spacing: 16px;

                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;
                    Text { text: "Need patent protection?"; font-size: 14px; color: Theme.text-muted; }
                    YesNoSkipCombo { current-value <=> root.patent-an; }
                }

                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;
                    Text { text: "Want to relicense derivatives?"; font-size: 14px; color: Theme.text-muted; }
                    YesNoSkipCombo { current-value <=> root.relicense-an; }
                }
            }
        }
    }

    ActionButton {
        text: "Check Compatibility";
        clicked => { root.check-compatibility(); }
    }

    ResultsPanel {
        output-text: root.output-text;
    }
}
