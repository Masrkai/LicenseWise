import { Button, ScrollView } from "std-widgets.slint";

export global Theme {
    in-out property <bool> dark-mode: true;
    out property <brush> primary: dark-mode ? #818cf8 : #4f46e5;
    out property <brush> primary-hover: dark-mode ? #6366f1 : #4338ca;
    out property <brush> primary-light: dark-mode ? #1e1b4b : #eef2ff;
    out property <brush> text-color: dark-mode ? #f1f5f9 : #1e293b;
    out property <brush> text-muted: dark-mode ? #94a3b8 : #64748b;
    out property <brush> warning: #f59e0b;
    out property <brush> success: #10b981;
    out property <brush> background: dark-mode ? #0f172a : #f1f5f9;
    out property <brush> surface: dark-mode ? #1e293b : #ffffff;
    out property <brush> border: dark-mode ? #334155 : #e2e8f0;
    out property <brush> focus-ring: dark-mode ? #818cf8 : #4f46e5;
    out property <length> font-size-micro: 12px;
    out property <length> font-size-label: 14px;
    out property <length> font-size-body: 16px;
    out property <length> font-size-heading: 22px;
    out property <length> font-size-subheading: 16px;
    out property <length> spacing-unit: 8px;
    out property <length> radius: 8px;
}

export component ActionButton inherits Button {
    primary: true;
    min-height: 44px;
}

export component OutputScrollView inherits ScrollView {
    // Ensuring it can expand
    vertical-stretch: 1;
    horizontal-stretch: 1;
}
