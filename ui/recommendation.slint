import { ComboBox } from "std-widgets.slint";
import { Theme, ActionButton } from "styles.slint";
import { Question } from "types.slint";
import { ResultsPanel } from "results.slint";

export component RecommendationTab inherits HorizontalLayout {
    spacing: 16px;
    padding: 0px;

    in property <[Question]> visible_questions;
    in-out property <int> current_question_index: 0;
    in-out property <int> total_visible_questions: 0;
    callback on_answer_changed(string, string);
    callback get-recommendation();
    callback go-to-previous();
    callback go-to-next();
    in-out property <string> output-text: "Results will appear here after clicking the button above";

    // LEFT COLUMN: Inputs
    VerticalLayout {
        spacing: 16px;
        horizontal-stretch: 1;
        vertical-stretch: 1;
        alignment: start;

        Text {
            text: "Project Requirements";
            font-size: Theme.font-size-heading;
            color: Theme.text-color;
        }

        // Progress indicator
        if root.total_visible_questions > 0: Text {
            text: "Question " + (root.current_question_index + 1) + " of " + root.total_visible_questions;
            font-size: Theme.font-size-label;
            color: Theme.text-muted;
        }

        // Dynamic Questions - show only the current question
        for q in visible_questions: VerticalLayout {
            spacing: 4px;
            Text { text: q.question; font-size: 14px; wrap: word-wrap; color: Theme.text-muted; }
            ComboBox {
                model: q.choices;
                current-value: q.current_answer;
                min-height: 32px;
                selected(v) => { root.on_answer_changed(q.fact_name, v); }
            }
        }

        // Navigation buttons
        HorizontalLayout {
            spacing: 8px;
            if root.current_question_index > 0: ActionButton {
                text: "Previous";
                clicked => { root.go-to-previous(); }
            }
            if root.current_question_index < root.total_visible_questions - 1: ActionButton {
                text: "Next";
                clicked => { root.go-to-next(); }
            }
        }

        ActionButton {
            text: "Get Recommendation";
            clicked => { root.get-recommendation(); }
        }
    }
    // RIGHT COLUMN: Results
    ResultsPanel {
        horizontal-stretch: 1;
        vertical-stretch: 1;
        output-text: root.output-text;
    }

}
